<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f7fafc;" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mediclinic.controllers.PatientFormController">

    <Label text="Nouvelle Fiche Patient" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2b6cb0;"/>

    <GridPane vgap="10" hgap="10">
        <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="CIN :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="cinField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Téléphone :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="telField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Mutuelle :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="mutuelleBox" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200.0"/>

        <Label text="Date Naiss :" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateNaissPicker" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" style="-fx-background-color: #cbd5e0;"/>
        <Button text="Enregistrer" onAction="#handleSave" style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>