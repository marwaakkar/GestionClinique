<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mediclinic.controllers.MedecinController">
    <top>
        <Label text="Espace Médecin - Liste d'attente" style="-fx-font-size: 24; -fx-padding: 20; -fx-text-fill: #2c5282;"/>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <TableView fx:id="waitingTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150" />
                    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="150" />
                    <TableColumn fx:id="colCin" text="CIN" prefWidth="100" />
                </columns>
            </TableView>
            <Button text="Commencer Consultation" onAction="#handleStartConsultation" prefHeight="40" style="-fx-background-color: #2b6cb0; -fx-text-fill: white;"/>
        </VBox>
    </center>
</BorderPane>