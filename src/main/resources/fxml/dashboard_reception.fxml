<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f7fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mediclinic.controllers.ReceptionController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Gestion des Patients" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2b6cb0;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher par Nom ou CIN..." prefWidth="350.0" prefHeight="35.0"/>
        <Button text="Rechercher" onAction="#refreshAll" prefHeight="35.0" style="-fx-background-color: #4a5568; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Nouveau Patient" onAction="#handleNewPatient" prefHeight="35.0" style="-fx-background-color: #48bb78; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Prendre RDV" onAction="#handleTakeRDV" style="-fx-background-color: #ed8936; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="patientTable" prefHeight="250.0">
        <columns>
            <TableColumn fx:id="colNom" text="Nom" />
            <TableColumn fx:id="colPrenom" text="Prénom" />
            <TableColumn fx:id="colCin" text="CIN" />
            <TableColumn fx:id="colTel" text="Téléphone" />
            <TableColumn fx:id="colMutuelle" text="Mutuelle" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <Separator />

    <Label text="File d'attente / Mouvements du jour" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c5282;"/>

    <TableView fx:id="rdvTable" prefHeight="250.0">
        <columns>
            <TableColumn fx:id="colRdvPatient" text="Patient" prefWidth="200" />
            <TableColumn fx:id="colRdvHeure" text="Heure" />
            <TableColumn fx:id="colRdvStatut" text="Statut" />
            <TableColumn fx:id="colOrdonnance" text="Ordonnance" />
            <TableColumn fx:id="colFacture" text="Facture / Paiement" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>